---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import VrakovisteSidebar from '../components/VrakovisteSidebar.astro';
---

<Layout title="Škoda Superb 1.9 TDI | Autovrakoviště">
    <Breadcrumbs />

    <div class="container">
        <div class="vrakoviste-layout">
            <VrakovisteSidebar />

            <main class="vrakoviste-main">
                <div class="product-detail-grid">
                    <!-- Gallery Column -->
                    <div class="product-gallery">
                        <div class="main-img-wrap" id="mainImageWrap" style="cursor: pointer;">
                            <div class="detail-badges-left">
                                <span class="badge-tag-item sleva">Sleva</span>
                                <span class="badge-tag-item bestseller">Bestseller</span>
                            </div>
                            <div class="detail-badge-red">-16%</div>
                            <img id="mainImage"
                                src="https://images.unsplash.com/photo-1542282088-fe8426682b8f?auto=format&fit=crop&q=80&w=1000"
                                alt="Škoda Superb 1.9 TDI" />
                        </div>
                        <div class="thumb-grid">
                            <div class="thumb-item active" data-index="0"
                                data-src="https://images.unsplash.com/photo-1542282088-fe8426682b8f?auto=format&fit=crop&q=80&w=1000">
                                <img src="https://images.unsplash.com/photo-1542282088-fe8426682b8f?auto=format&fit=crop&q=80&w=300"
                                    alt="thumbnail 1" />
                            </div>
                            <div class="thumb-item" data-index="1"
                                data-src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=1000">
                                <img src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=300"
                                    alt="thumbnail 2" />
                            </div>
                            <div class="thumb-item" data-index="2"
                                data-src="https://images.unsplash.com/photo-1542282088-fe8426682b8f?auto=format&fit=crop&q=80&w=1000">
                                <img src="https://images.unsplash.com/photo-1542282088-fe8426682b8f?auto=format&fit=crop&q=80&w=300"
                                    alt="thumbnail 3" />
                            </div>
                        </div>

                        <!-- Hidden lightbox gallery links -->
                        <div style="display: none;">
                            <a data-fslightbox="productGallery"
                                href="https://images.unsplash.com/photo-1542282088-fe8426682b8f?auto=format&fit=crop&q=80&w=1000"></a>
                            <a data-fslightbox="productGallery"
                                href="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&q=80&w=1000"></a>
                            <a data-fslightbox="productGallery"
                                href="https://images.unsplash.com/photo-1542282088-fe8426682b8f?auto=format&fit=crop&q=80&w=1000"></a>
                        </div>
                    </div>

                    <!-- Info Column -->
                    <div class="detail-info-wrap">
                        <h1>Škoda Superb 1.9 TDI</h1>
                        <p class="detail-subtitle">z Subaru Outback r.2002</p>

                        <div class="blue-info-box">
                            <h4>MÁME VOZY I V JINÝCH BARVÁCH A MOTORIZACÍCH NEŽ INZERUJEME.</h4>
                            <div class="blue-info-phone">ZAVOLEJTE A ZEPTEJTE SE: 608 78 11 11</div>
                            <p class="blue-info-text">
                                Vždycky se nám nepodaří dát všechny auta na web. Proto se informujte telefonicky na
                                skladovou dostupnost jiných barevných variant u tohoto vozidla.
                            </p>
                        </div>

                        <a href="#" class="btn btn-koupit">Koupit na eshopu</a>

                        <div class="product-description-wrap">
                            <div class="description-header">POPIS PRODUKTU</div>
                            <div class="description-content">
                                <p>Motor EJ25 2.5 AWD 115kW z Subaru Outback r.2002</p>
                                <p>Kód produktu: 17480</p>
                                <p>V případě zájmu napište nebo zavolejte.</p>
                                <p>Díly zasíláme dobírkou po celé ČR a SK nebo osobní odběr.</p>
                                <p>Záruka na veškeré starší náhradní díly je 30. dní.</p>
                                <p>Z časových důvodů upřednostňujeme telefonický kontakt v době od 8:00 do 16:00. Na
                                    email samozřejmě odpovíme, ale nemusí to být ihned.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Form Section -->
                <section class="vrakoviste-contact-section">
                    <div class="contact-form-header">
                        <h2>Máte dotaz? Napište nám</h2>
                        <p>Chcete-li se na cokoliv zeptat, tak neváhejte a kontaktujte nás.</p>
                    </div>

                    <form action="#" class="contact-form">
                        <div class="contact-form-grid">
                            <div class="form-group">
                                <label for="name">Vaše jméno</label>
                                <input type="text" id="name" placeholder="Petr Novák" />
                            </div>
                            <div class="form-group">
                                <label for="phone">Váš telefon</label>
                                <input type="tel" id="phone" />
                            </div>
                        </div>

                        <div class="form-group" style="margin-bottom: 3rem;">
                            <label for="email">Váš e-mail</label>
                            <input type="email" id="email" />
                        </div>

                        <div class="form-group" style="margin-bottom: 4rem;">
                            <label for="message">Zpráva</label>
                            <textarea id="message" placeholder="text zprávy...."></textarea>
                        </div>

                        <div class="contact-form-footer">
                            <label class="gdpr-wrap">
                                <input type="checkbox" />
                                <span>Odesláním formuláře potvrzuji seznámení s Poučením a zpracování osobních
                                    údajů</span>
                            </label>
                            <button type="submit" class="btn btn-send-form">Odeslat dotaz</button>
                        </div>
                    </form>
                </section>
            </main>
        </div>
    </div>

    <!-- Lightbox Script -->
    <script is:inline src="/vendor/fslightbox/fslightbox.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const thumbs = document.querySelectorAll('.thumb-item');
            const mainImage = document.getElementById('mainImage');
            const mainImageWrap = document.getElementById('mainImageWrap');
            let currentIndex = 0;

            if (thumbs.length && mainImage && mainImageWrap) {
                // Initialize active class for first item
                thumbs[0].classList.add('active');

                thumbs.forEach((thumb) => {
                    thumb.addEventListener('click', function () {
                        // Remove active class from all, add to clicked
                        thumbs.forEach(t => t.classList.remove('active'));
                        this.classList.add('active');

                        // Update image
                        const newSrc = this.getAttribute('data-src');
                        if (newSrc) {
                            mainImage.src = newSrc;
                        }

                        // Update index for lightbox
                        currentIndex = parseInt(this.getAttribute('data-index') || '0', 10);
                    });
                });

                // Open lightbox
                mainImageWrap.addEventListener('click', () => {
                    if (typeof fsLightboxInstances !== 'undefined' && fsLightboxInstances['productGallery']) {
                        fsLightboxInstances['productGallery'].open(currentIndex);
                    }
                });
            }
        });
    </script>
</Layout>