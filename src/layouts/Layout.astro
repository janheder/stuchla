---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PoptavkaModal from '../components/PoptavkaModal.astro';

const { title = 'IVRAKY.cz - Ekologická likvidace autovraků a autovrakoviště' } = Astro.props;
---

<!DOCTYPE html>
<html lang="cs">

<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <meta name='viewport' content='width=device-width, initial-scale=1'>

    <title>{title}</title>
    <meta name="description"
        content="Ekologická likvidace autovraků s protokolem na počkání. Výkup vraků za nejlepší ceny, odvoz zdarma. Prodej náhradních dílů se zárukou.">
    <meta name="keywords"
        content="likvidace autovraků, autovrakoviště, výkup aut, náhradní díly, ekologická likvidace, Ostrava, Olomouc, Zlín">

    <!-- Stylesheets -->
    <link rel='stylesheet' type='text/css' media='screen' href='/style.css'>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=Sora:wght@100..800&display=swap"
        rel="stylesheet">
</head>

<body>
    <Header />
    <slot />
    <Footer />
    <PoptavkaModal />

    <script is:inline src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"></script>
    <script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            if (document.querySelector('#testimonial-slider')) {
                new Splide('#testimonial-slider', {
                    type: 'loop',
                    perPage: 3,
                    gap: '2rem',
                    breakpoints: {
                        1024: {
                            perPage: 2,
                        },
                        768: {
                            perPage: 1,
                        },
                    },
                    arrows: true,
                    pagination: true,
                }).mount();
            }
        });
    </script>
</body>

</html>