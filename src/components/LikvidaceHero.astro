---
---
<section class="likvidace-hero">
    <div class="likvidace-hero-bg" style="background-image: url('/img/hero2.jpg');"></div>
    <div class="container likvidace-hero-container">
        <div class="likvidace-hero-content">
            <h1 class="likvidace-hero-title">Ekologická likvidace autovraků</h1>
            <p class="likvidace-hero-text">Křivoklát / Ostrava / Sviadnov a pro přilehlé okolí</p>

            <div class="likvidace-hero-action">
                <span class="likvidace-action-label">Kovostěš Ostrava s.r.o.<br>infolinka pro ekologickou
                    likvidaci</span>
                <a href="tel:+420606741111" class="btn btn-phone"><img src="/img/icon-phone-dark.svg" alt="Phone"
                        class="btn-icon"> 606 74 11 11</a>
            </div>
        </div>

        <div class="likvidace-hero-form">
            <h3 class="form-title">Chcete znát cenu za váš autovrak?</h3>
            <p class="form-subtitle">Nechte nám kontakt a obratem se Vám ozveme:</p>
            <form action="#" method="POST">
                <div class="form-group">
                    <input type="text" name="name" placeholder="Jméno" required>
                </div>
                <div class="form-group">
                    <input type="tel" name="phone" placeholder="Telefon" required>
                </div>
                <div class="form-group">
                    <input type="text" name="car" placeholder="Značka a model vozidla" required>
                </div>
                <div class="form-checkbox">
                    <input type="checkbox" id="likv-consent" name="consent" required>
                    <label for="likv-consent">Souhlasím se zpracováním osobních údajů (pouze k vyřízení poptávky nebo
                        dotazu)</label>
                </div>
                <button type="submit" class="btn btn-submit">Odeslat poptávku &rarr;</button>
            </form>
        </div>
    </div>
    <div class="likvidace-hero-badges">
        <div class="container">
            <div class="likvidace-badges-grid">
                <div class="likvidace-badge">
                    <div class="badge-icon"><img src="/img/icon-likvidace.svg" alt="Zdarma"></div>
                    <span class="likvidace-badge-label">Zdarma</span>
                    <span class="likvidace-badge-value">Protokol o převzetí s likvidací a<br>případně vyřízení EKO
                        daně</span>
                </div>
                <div class="likvidace-badge">
                    <div class="badge-icon"><img src="/img/icon-likvidace.svg" alt="Zdarma"></div>
                    <span class="likvidace-badge-label">Zdarma</span>
                    <span class="likvidace-badge-value">Odhlášení z registru vozidel a<br>evidence vozidel</span>
                </div>
                <div class="likvidace-badge">
                    <div class="badge-icon"><img src="/img/icon-likvidace.svg" alt="Zdarma"></div>
                    <span class="likvidace-badge-label">Zdarma</span>
                    <span class="likvidace-badge-value">Odtah autovraku až k naší<br>provozovně</span>
                </div>
            </div>
        </div>
    </div>
</section>