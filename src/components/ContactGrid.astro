}
---

<section class="contact-grid-section">
    <div class="container">
        <div class="contact-grid">
            {contacts.map((contact) => (
            <div class="contact-card">
                <div class="contact-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                        stroke-linejoin="round" set:html={getIconContent(contact.icon)} />
                </div>
                <h3 class="contact-card-title">{contact.title}</h3>

                <div class="contact-card-phone-wrapper">
                    <div class="contact-card-phone-icon">
                        <img src="/img/icon-phone-dark.svg" alt="Telefon" />
                    </div>
                    <div class="contact-card-phone-numbers">
                        <a href={`tel:${contact.phone1.replace(/\s/g, '' )}`}>{contact.phone1}</a>
                        {contact.phone2 && <a href={`tel:${contact.phone2.replace(/\s/g, '' )}`}>{contact.phone2}</a>}
                    </div>
                </div>
            </div>
            ))}
        </div>
    </div>
</section>