---
---

<section class="contact-section-details --light">
    <div class="container">
        <div class="contact-details-grid">
            <div class="contact-map">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2572.71261!2d18.3117468!3d49.6874285!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4713f044719b35b1%3A0x8729906d27464010!2sK%20%C4%8Cisti%C4%8Dce%20500%2C%20739%2025%20Sviadnov!5e0!3m2!1scs!2scz!4v1700000000000!5m2!1scs!2scz"
                    width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>

            <div class="contact-info">
                <h2>Autovrakoviště, Autoservis a sklady</h2>

                <div class="contact-address">
                    <p>Autovrakoviště Sviadnov s.r.o.</p>
                    <p>K čističce 500</p>
                    <p>739 25 Sviadnov</p>
                </div>

                <div class="contact-ident">
                    <p>IČ: 05477280</p>
                    <p>DIČ: cz05477280</p>
                </div>

                <div class="contact-info-list">
                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <img src="/img/icon-phone-dark.svg" alt="Telefon" />
                        </div>
                        <div class="contact-info-text">
                            <a href="tel:+420602660066">+420 602 660 066</a>
                            <span>Po - Pá 8:00 - 16:00</span>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="20" height="16" x="2" y="4" rx="2" />
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                            </svg>
                        </div>
                        <div class="contact-info-text">
                            <a href="mailto:stuchla@stuchla.cz">stuchla@stuchla.cz</a>
                        </div>
                    </div>
                </div>

                <div class="contact-hours">
                    <p>otevírací doba :</p>
                    <p>Po–Pá: 8.00 - 12.00 13.00 - 16.00</p>
                </div>
            </div>
        </div>

        <div class="contact-services">
            <h3>Zde vyřídíte:</h3>
            <div class="contact-services-grid">
                <div class="service-badge">
                    <span class="dot"></span>
                    Poptávka a prodej použitých náhradních dílů SE ZÁRUKOU
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    Autoservis
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    pneuservis
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    geometrie vozidel
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    opravy a plnění klimatizací
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    ekologická likvidace vozidel
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    zapůjčení vleků (pro 1 nebo 2 auta)
                </div>
            </div>
        </div>

        <div class="contact-gallery">
            <a href="/img/hero1.jpg" data-fslightbox="galleryLight">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="galleryLight">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="galleryLight">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="galleryLight">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="galleryLight">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="galleryLight">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
        </div>
    </div>
</section>

<!-- Lightbox library -->
<script is:inline src="/vendor/fslightbox/fslightbox.min.js"></script>