---
---

<section class="contact-section-details">
    <div class="container">
        <div class="contact-details-grid">
            <div class="contact-map">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2572.779507981503!2d18.318854076391444!3d49.68617837145784!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4713f01524e756df%3A0xe962d3081e7d23d8!2sOstravsk%C3%A1%2049%2C%20739%2025%20Sviadnov!5e0!3m2!1scs!2scz!4v1700000000000!5m2!1scs!2scz"
                    width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>

            <div class="contact-info">
                <h2>Kanceláře Autovrakoviště Sviadnov</h2>

                <div class="contact-address">
                    <p style="color: var(--gray); font-size: 1.4rem; margin-bottom: 1.6rem;">( prodej použitých
                        náhradních dílů přesunut na druhou pobočku: K čističce 500, Sviadnov )</p>
                    <p>Ostravská 49</p>
                    <p>739 25 Sviadnov</p>
                </div>

                <div class="contact-info-list">
                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <img src="/img/icon-phone-dark.svg" alt="Telefon" />
                        </div>
                        <div class="contact-info-text">
                            <a href="tel:606741111">606 741 111</a>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="20" height="16" x="2" y="4" rx="2" />
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                            </svg>
                        </div>
                        <div class="contact-info-text">
                            <a href="mailto:stuchla@stuchla.cz">stuchla@stuchla.cz</a>
                        </div>
                    </div>
                </div>

                <div class="contact-hours">
                    <p>otevírací doba :</p>
                    <p>Po-Pá: 8.00 - 12.00 13.00 - 16.00</p>

                    <p style="margin-top: 1.6rem; color: var(--red); font-weight: 500;">Zavřeno: od 20.12.2025 do
                        4.1.2026</p>
                </div>
            </div>
        </div>

        <div class="contact-services">
            <h3>Zde vyřídíte:</h3>
            <div class="contact-services-grid">
                <div class="service-badge">
                    <span class="dot"></span>
                    ekologická likvidace vozidla | vystavení protokolu o likvidaci
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    výkupní ceny vozidel a autovraků
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    prodej nových autodílů
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    autoservis: příjem, dotazy | náhradní vozidla v době opravy
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    autobazar
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    pojištění vozidel
                </div>
                <div class="service-badge">
                    <span class="dot"></span>
                    pronájem vozidel
                </div>
            </div>
        </div>

        <div class="contact-gallery">
            <a href="/img/hero1.jpg" data-fslightbox="gallery">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="gallery">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="gallery">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="gallery">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="gallery">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
            <a href="/img/hero1.jpg" data-fslightbox="gallery">
                <img src="/img/hero1.jpg" alt="Autovrakoviště Sviadnov" loading="lazy" />
            </a>
        </div>
    </div>
</section>

